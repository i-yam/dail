# Telegram bot token from @BotFather (required).
BOT_TOKEN=

# URL of the model /detect service.
MODEL_URL=http://localhost:8000

# How long to wait for the model to reply before returning an error verdict.
MODEL_TIMEOUT_S=20

# Auto-detect language and translate non-English input to English
# before sending to the model. Set to 0 to disable.
AUTO_TRANSLATE=1

# Optional: comma-separated Telegram user IDs who get admin-only commands.
ADMIN_USER_IDS=
