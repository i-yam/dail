# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Teammates' classification API endpoint
# If not set, the bot uses its built-in mock classifier (keyword heuristics)
# Example: CLASSIFIER_API_URL=http://localhost:8001
CLASSIFIER_API_URL=

# Optional path to disinfo article CSV used by matcher.
# Default: data/processed/euvsdisinfo_reports.csv
# NOTE: file must contain enriched columns: title, summary, response, report_url.
DISINFO_ARTICLES_CSV=

# Timeout in seconds for calls to the classifier API (default: 10)
CLASSIFIER_TIMEOUT=10

# Optional LLM verification for retrieved disinfo matches (OpenAI-compatible API).
# If these are set, the matcher can run a second-stage check:
#   "Does message actually support this disinfo claim, or is it different/neutral?"
# Example:
# DISINFO_LLM_API_URL=https://api.openai.com/v1/chat/completions
# DISINFO_LLM_API_KEY=sk-...
# DISINFO_LLM_MODEL=gpt-4o-mini
DISINFO_LLM_API_URL=https://api.openai.com/v1/chat/completions
DISINFO_LLM_API_KEY=your_key_here
DISINFO_LLM_MODEL=gpt-4o-mini
DISINFO_LLM_TIMEOUT=20
